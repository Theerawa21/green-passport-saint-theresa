{
  "rules": {
    "chatMessages": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp"],
        "$messageId": {
          ".validate": "newData.hasChildren(['MessageText','UserID','DisplayName','Timestamp']) && newData.child('MessageText').isString() && newData.child('MessageText').val().length <= 500 && newData.child('UserID').val() === auth.uid"
        }
      }
    },
    "chatTyping": {
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth.uid === $uid"
        }
      }
    }
  }
}
