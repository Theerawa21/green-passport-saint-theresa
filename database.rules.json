{
  "rules": {
    "chatMessages": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp"],
        "$messageId": {
          ".validate": "newData.hasChildren(['text','userId','displayName','timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 500 && newData.child('userId').val() === auth.uid"
        }
      }
    },
    "chatTyping": {
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth.uid === $uid"
        }
      }
    }
  }
}
